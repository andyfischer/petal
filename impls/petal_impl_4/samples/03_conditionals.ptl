// Conditionals and comparison
let x = 10
let y = 20

if (x < y) {
    print("x is less than y")
}

if (x == 10) {
    print("x equals 10")
}

if (x > y) {
    print("x is greater than y")
} else {
    print("x is not greater than y")
}

// Boolean operations
let a = true
let b = false

if (a and not b) {
    print("a is true and b is false")
}

if (a or b) {
    print("at least one of a or b is true")
}

// Chained comparisons
let z = 15
if (x < z and z < y) {
    print("x < z < y")
}
