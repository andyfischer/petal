// Functions and recursion

fn add(a, b) {
    a + b
}

fn factorial(n) {
    if n <= 1 {
        1
    } else {
        n * factorial(n - 1)
    }
}

fn fibonacci(n) {
    if n <= 1 {
        n
    } else {
        fibonacci(n - 1) + fibonacci(n - 2)
    }
}

print("add(5, 3) =", add(5, 3))
print("factorial(5) =", factorial(5))
print("fibonacci(10) =", fibonacci(10))
