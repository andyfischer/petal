// Traits (interfaces)
trait Drawable {
    func draw(self, canvas: Canvas)
    func bounds(self) -> Rectangle
}

trait Updatable {
    func update(self, delta_time: float)
}

// Implementing traits
struct Sprite {
    texture: Texture,
    position: Vector,
    size: Vector
}

impl Drawable for Sprite {
    func draw(self, canvas: Canvas) {
        canvas.draw_texture(self.texture, self.position, self.size)
    }
    
    func bounds(self) -> Rectangle {
        return Rectangle{
            x: self.position.x,
            y: self.position.y,
            width: self.size.x,
            height: self.size.y
        }
    }
}

// Generic traits
trait Container<T> {
    func add(self, item: T)
    func remove(self, item: T) -> bool
    func contains(self, item: T) -> bool
}

// Trait bounds
func draw_all<T: Drawable>(items: [T], canvas: Canvas) {
    for item in items {
        item.draw(canvas)
    }
}