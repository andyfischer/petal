// A small library module — see imports.ptl for a script that imports it.
// A top-level fn / let / state is exported only when marked `export`;
// everything else (including _underscore names) is module-private.

export let ellipsis = "..."

fn _cut(s, n)
  slice(s, 0, n)
end

export fn truncate(s, max)
  if len(s) > max then
    _cut(s, max) ++ ellipsis
  else
    s
  end
end

export fn shout(s)
  s ++ "!"
end
