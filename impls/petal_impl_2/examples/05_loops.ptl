// Loops and iteration

// For loop with range
print("Counting 0 to 9:")
for i in range(0, 10) {
    print(i)
}

// Nested loops
print("\nMultiplication table:")
for i in range(1, 6) {
    for j in range(1, 6) {
        print(i, "x", j, "=", i * j)
    }
}

// Using lists
let numbers = [1, 2, 3, 4, 5]
print("\nIterating over list:")
for num in numbers {
    print("Number:", num)
}
