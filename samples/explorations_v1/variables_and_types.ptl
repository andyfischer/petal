// Variable declarations
let x = 42
let y = 3.14
let name = "Petal"
let flag = true
let empty = null

// Type annotations
let count: int = 100
let price: float = 99.99
let message: string = "Hello, world!"
let active: bool = false

// Destructuring
let [x, y] = [10, 20]
let {name, age} = {name: "Alice", age: 30}
