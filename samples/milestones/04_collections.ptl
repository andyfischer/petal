// Milestone 4: Arrays and objects
// Test collection literal syntax

// Array literals
[]
[1, 2, 3]
[1 2 3]  // Optional commas
["a", "b", "c"]
[true, false, null]

// Nested arrays
[[1, 2], [3, 4]]
[
    [1, 2, 3],
    [4, 5, 6]
]

// Object literals
{}
{x: 10, y: 20}
{
    name: "Alice"
    age: 30
    active: true
}

// Nested objects
{
    position: {x: 0, y: 0}
    velocity: {x: 1.5, y: -2.0}
    color: :FF0000
}

// Array and object access
arr[0]
obj.field
person["name"]
matrix[x][y]