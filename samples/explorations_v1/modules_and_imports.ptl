    func cos(x: float) -> float {
        // Implementation
    }
    
    struct Vector {
        x: float,
        y: float
    }
    
    impl Vector {
        func magnitude(self) -> float {
            return sqrt(self.x * self.x + self.y * self.y)
        }
    }
}

