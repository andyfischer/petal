// State management - the key feature of Petal!

fn counter() {
    state count = 0
    count = count + 1
    count
}

print("First call:", counter())
print("Second call:", counter())
print("Third call:", counter())
print("Fourth call:", counter())

// State with conditional initialization
fn toggle() {
    state is_on = false
    is_on = !is_on
    is_on
}

print("\nToggle demo:")
print("Toggle:", toggle())
print("Toggle:", toggle())
print("Toggle:", toggle())
print("Toggle:", toggle())
