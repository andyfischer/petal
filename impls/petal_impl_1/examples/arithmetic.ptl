// Basic arithmetic in Petal

print("Basic Arithmetic")
print("================")

let a = 10
let b = 3

print("a =", a)
print("b =", b)
print("")

print("a + b =", a + b)
print("a - b =", a - b)
print("a * b =", a * b)
print("a / b =", a / b)
print("a % b =", a % b)

print("")
print("Float arithmetic:")
let x = 3.14
let y = 2.0
print("x =", x)
print("y =", y)
print("x * y =", x * y)

print("")
print("Mixed arithmetic:")
print("a + x =", a + x)
