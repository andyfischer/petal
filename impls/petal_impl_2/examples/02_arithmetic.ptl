// Basic arithmetic operations

let a = 10
let b = 5

print("Addition:", a + b)
print("Subtraction:", a - b)
print("Multiplication:", a * b)
print("Division:", a / b)
print("Modulo:", a % b)

let x = 3.14
let y = 2.0

print("Float addition:", x + y)
print("Float multiplication:", x * y)

print("Mixed types:", a + x)
