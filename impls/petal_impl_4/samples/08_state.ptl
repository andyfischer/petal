// Petal's unique 'state' keyword
// State persists during execution

// Initialize state
state counter = 0

// Display initial state
print("Initial counter:", counter)

// Update state using regular assignment
counter = counter + 1
print("After increment:", counter)

// Multiple state variables
state x = 10
state y = 20
print("x + y =", x + y)

// State persists across reads
state message = "Hello"
print("Message:", message)
message = message + " World"
print("Updated:", message)
