{
  "services": [
    {
      "name": "playground-api",
      "shell": "node --watch src/api.ts",
      "root": "playground"
    },
    {
      "name": "playground-web",
      "shell": "pnpm dev",
      "root": "playground/web"
    },
    {
      "name": "dev",
      "shell": "npx vite --port 4009",
      "root": "petal-web"
    },
    {
      "name": "diagram-canvas",
      "shell": "npx vite --port 4012",
      "root": "petal-diagram-canvas"
    }
  ]
}